{
  "name": "locreport",
  "version": "0.0.0",
  "description": "Analyze a GitHub repo's lines of code over time, split by role (app, tests, config, comments, build).",
  "type": "module",
  "bin": {
    "locreport": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
